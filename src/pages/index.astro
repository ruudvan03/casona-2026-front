---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BookingForm from "../components/BookingForm.jsx";
import RoomCards from "../components/RoomCards.astro";
// IMPORTAMOS LOS COMPONENTES NUEVOS
import Gallery from "../components/Gallery.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<Layout title="Palapa La Casona | Eventos y Hospedaje">
  <Navbar />
  
  <main class="pt-24 overflow-x-hidden">
    <section id="reservas" class="max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center">
      
      <div class="space-y-6">
        <div class="animate-fade-in-up" style="animation-delay: 0.1s; animation-fill-mode: both;">
          <span class="inline-block bg-emerald-50 text-emerald-700 font-black uppercase tracking-[0.2em] text-xs px-4 py-2 rounded-full border border-emerald-100 shadow-sm">
            Costa de Oaxaca
          </span>
        </div>
        
        <h1 class="animate-fade-in-up text-6xl md:text-7xl font-black text-slate-900 leading-[1.1] mt-4 uppercase" style="animation-delay: 0.3s; animation-fill-mode: both;">
          Tu evento en <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500">el paraíso</span>.
        </h1>
        
        <p class="animate-fade-in-up text-xl text-slate-600 leading-relaxed max-w-lg" style="animation-delay: 0.5s; animation-fill-mode: both;">
          Palapa, alberca y descanso exclusivo en Llano Grande, Santa María Tonameca.
        </p>
      </div>

      <div class="relative animate-fade-in-up" style="animation-delay: 0.7s; animation-fill-mode: both;">
        <div class="absolute -top-10 -right-10 w-72 h-72 bg-emerald-200 rounded-full blur-3xl opacity-40 -z-10 animate-blob mix-blend-multiply"></div>
        <div class="absolute -bottom-10 -left-10 w-72 h-72 bg-teal-200 rounded-full blur-3xl opacity-40 -z-10 animate-blob animation-delay-2000 mix-blend-multiply"></div>
        
        <div class="animate-float">
          <BookingForm client:load />
        </div>
      </div>
    </section>

    <div class="animate-fade-in-up" style="animation-delay: 0.4s; animation-fill-mode: both;">
      <RoomCards />
    </div>

    <Gallery />

    <section id="contacto" class="py-24 bg-slate-50 overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-6 text-center">
        
        <div class="animate-fade-in-up" style="animation-delay: 0.2s; animation-fill-mode: both;">
          <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tight mb-4">Ubicación</h2>
          <p class="text-slate-500 text-lg mb-16 italic">
            Llano Grande, Santa María Tonameca, Oaxaca, México.
          </p>
        </div>

        <div class="relative group max-w-5xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s; animation-fill-mode: both;">
          <div class="absolute -inset-1 bg-gradient-to-r from-emerald-600 to-teal-900 rounded-[2.5rem] blur opacity-20 group-hover:opacity-50 transition duration-1000 group-hover:duration-200 animate-pulse-slow"></div>
          
          <div class="relative h-[500px] w-full bg-white rounded-[2rem] overflow-hidden shadow-2xl border border-slate-100 transform transition-transform duration-700 hover:scale-[1.02]">
            
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15360.643493236696!2d-96.54631655!3d15.742626650000002!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85b8d7a645836183%3A0xaa2fd69b1b5b584d!2sPalapa%20La%20Casona!5e0!3m2!1ses-419!2smx!4v1774785904662!5m2!1ses-419!2smx" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              class="grayscale hover:grayscale-0 transition-all duration-1000 ease-in-out"
            ></iframe>

          </div>

          <a 
            href="https://www.google.com/maps/search/?api=1&query=Palapa+La+Casona+Llano+Grande+Oaxaca" 
            target="_blank" 
            class="absolute bottom-8 right-8 bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold shadow-[0_10px_40px_rgba(0,0,0,0.3)] hover:bg-emerald-600 transition-all duration-300 flex items-center gap-3 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(16,185,129,0.4)] group/btn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover/btn:animate-bounce" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
            </svg>
            Llegar con GPS
          </a>
        </div>
      </div>
    </section>
  </main>

  <WhatsAppButton />

  <footer class="py-12 bg-white border-t border-slate-100 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-emerald-50/50 -z-10"></div>
    <p class="text-slate-500 font-medium text-sm">
      © {new Date().getFullYear()} <span class="text-slate-900 font-bold">Palapa La Casona</span>. Todos los derechos reservados.
    </p>
  </footer>
</Layout>

<style is:global>
  /* 1. Entrada suave desde abajo */
  @keyframes fadeInUp {
    from { 
      opacity: 0; 
      transform: translateY(30px); 
    }
    to { 
      opacity: 1; 
      transform: translateY(0); 
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 2. Efecto de "Flotar" para el formulario */
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
    100% { transform: translateY(0px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* 3. Manchas de color de fondo que "Respiran" (Blobs) */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }

  /* 4. Brillo sutil del mapa */
  @keyframes pulseSlow {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.4; }
  }
  .animate-pulse-slow {
    animation: pulseSlow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>